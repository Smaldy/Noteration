# Auto detect text files and perform LF normalization
* text=auto

# macOS run scripts must stay LF or the shebang breaks on Unix
*.command text eol=lf
*.sh      text eol=lf

# Arch packaging: makepkg parses PKGBUILD as bash and reads the .desktop entry on
# Linux — CRLF would break both.
PKGBUILD   text eol=lf
*.desktop  text eol=lf

# Windows run scripts keep CRLF
*.bat text eol=crlf
