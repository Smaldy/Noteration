# ───── Python / backend ─────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ───── Node / frontend ─────
node_modules/
dist/
build/
.vite/
*.local

# ───── Packaging build artifacts (never commit; large) ─────
packaging/installer_output/

# ───── Noteration runtime data (never commit) ─────
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
backend/cache/
backend/benchmark/samples/*.pdf

# ───── Runtime logs (never commit) ─────
*.log

# ───── Secrets / env ─────
.env
.env.*
*.key
secrets.*

# ───── Editor / OS ─────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
# LibreOffice/office lock files (leak username + hostname + home path)
.~lock.*#

# ───── Local AI-assistant state (machine-local; may hold personal config) ─────
.claude/
.claude-flow/
